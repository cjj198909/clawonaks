    {
      "mode": "managed",
      "type": "azurerm_api_management_api_policy",
      "name": "openai",
      "provider": "provider[\"registry.terraform.io/hashicorp/azurerm\"]",
      "instances": [
        {
          "index_key": 0,
          "schema_version": 2,
          "attributes": {
            "api_management_name": "openclaw-apim",
            "api_name": "azure-openai",
            "id": "/subscriptions/55a5740e-376a-4d19-9be9-ae2be9c3731e/resourceGroups/openclaw-rg/providers/Microsoft.ApiManagement/service/openclaw-apim/apis/azure-openai",
            "resource_group_name": "openclaw-rg",
            "timeouts": null,
            "xml_content": "\u003c!-- APIM AI Gateway Policy (rendered by Terraform templatefile) --\u003e\r\n\u003c!-- Auth mode: api_key --\u003e\r\n\u003cpolicies\u003e\r\n\t\u003cinbound\u003e\r\n\t\t\u003cbase /\u003e\r\n\t\t\u003c!-- API Key mode: inject key from Named Value (backed by Key Vault) --\u003e\r\n\t\t\u003cset-header name=\"api-key\" exists-action=\"override\"\u003e\r\n\t\t\t\u003cvalue\u003e{{azure-openai-key}}\u003c/value\u003e\r\n\t\t\u003c/set-header\u003e\r\n\t\t\u003c!-- Remove any Authorization header from the client — Azure OpenAI may\r\n         reject an invalid Bearer token even when a valid api-key is present --\u003e\r\n\t\t\u003cset-header name=\"Authorization\" exists-action=\"delete\" /\u003e\r\n\t\t\u003c!-- Rate limiting: 60 calls/min per subscription (standard policy).\r\n         NOTE: LLM token-based policies (llm-token-limit, llm-emit-token-metric)\r\n         require API to be imported via the \"Language Model API\" portal flow.\r\n         For now, use standard rate limiting. Migrate to LLM policies when\r\n         re-importing the API via portal. --\u003e\r\n\t\t\u003crate-limit-by-key calls=\"60\" renewal-period=\"60\" counter-key=\"@(context.Subscription.Id)\" remaining-calls-variable-name=\"remainingCalls\" /\u003e\r\n\t\t\u003c!-- Ensure api-version is always a query parameter (Azure OpenAI requires it).\r\n         SDKs may send it as a header only, which causes 404. --\u003e\r\n\t\t\u003cset-query-parameter name=\"api-version\" exists-action=\"skip\"\u003e\r\n\t\t\t\u003cvalue\u003e2025-04-01-preview\u003c/value\u003e\r\n\t\t\u003c/set-query-parameter\u003e\r\n\t\t\u003c!-- Backend routing via pool (circuit breaker on individual backends) --\u003e\r\n\t\t\u003cset-backend-service backend-id=\"openai-backend-pool\" /\u003e\r\n\t\t\u003c!-- Azure OpenAI Responses API only supports /openai/responses (model in body),\r\n         NOT /openai/deployments/{model}/responses. Rewrite when SDK uses the\r\n         deployment-in-URL pattern. chat/completions and other paths pass through. --\u003e\r\n\t\t\u003cchoose\u003e\r\n\t\t\t\u003cwhen condition=\"@(context.Request.Url.Path.Contains(\u0026quot;/responses\u0026quot;))\"\u003e\r\n\t\t\t\t\u003crewrite-uri template=\"/responses\" copy-unmatched-params=\"true\" /\u003e\r\n\t\t\t\u003c/when\u003e\r\n\t\t\u003c/choose\u003e\r\n\t\u003c/inbound\u003e\r\n\t\u003cbackend\u003e\r\n\t\t\u003cbase /\u003e\r\n\t\u003c/backend\u003e\r\n\t\u003coutbound\u003e\r\n\t\t\u003cbase /\u003e\r\n\t\u003c/outbound\u003e\r\n\t\u003con-error\u003e\r\n\t\t\u003cbase /\u003e\r\n\t\u003c/on-error\u003e\r\n\u003c/policies\u003e",
            "xml_link": null
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0,
          "private": "eyJlMmJmYjczMC1lY2FhLTExZTYtOGY4OC0zNDM2M2JjN2M0YzAiOnsiY3JlYXRlIjoxODAwMDAwMDAwMDAwLCJkZWxldGUiOjE4MDAwMDAwMDAwMDAsInJlYWQiOjMwMDAwMDAwMDAwMCwidXBkYXRlIjoxODAwMDAwMDAwMDAwfSwic2NoZW1hX3ZlcnNpb24iOiIyIn0=",
          "dependencies": [
